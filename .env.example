# Copy this file to .env and fill in your values.
# Never commit .env — it is git-ignored.

# Docker Hub username (used by deploy.sh to tag and push images)
DOCKER_USERNAME=yourdockerhubusername

# SSH target for deploy.sh to auto-deploy after pushing images (optional)
# Format: user@host — must have SSH key auth set up (no password prompt)
SERVER_SSH=ubuntu@your-server-ip

# Supabase PostgreSQL connection string
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
DB_DSN=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Session cookie signing secret — use a random 32+ character string
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-32-char-string

# Session encryption key (base64), 16/24/32-byte decoded length.
# Recommended for confidentiality of cookie payload:
# openssl rand -base64 32
SESSION_ENCRYPTION_KEY=

# Allowed CORS origin for the frontend
# In production set this to your domain: https://stokely.quest
FRONTEND_ORIGIN=http://localhost:5173

# Optional cookie domain. Leave empty to use host-only cookies (recommended).
# Set only if you intentionally need cross-subdomain cookie sharing.
COOKIE_DOMAIN=

# Set to "true" in production to enforce Secure flag on session cookies (requires HTTPS)
COOKIE_SECURE=false

# SameSite mode for session cookie: lax (recommended), strict, none
COOKIE_SAMESITE=lax

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# SMTP (optional — required for email verification and password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public URL of the app (used in email links, e.g. https://stokely.quest)
APP_URL=
