### Phase 5 — Frontend Types & API Layer

**5A. Update `stokely-frontend/src/types/habit.d.ts`:**
```typescript
export interface HabitType {
    id: number; name: string; complete: boolean; recurrence: string; positiveType: boolean;
    icon: string; recurrenceEnd?: string; notes: string; reminderTime: string;
    streak: number; hasFreeze: boolean; createdAt: string;
}
export type DashboardView = 'daily' | 'all' | 'calendar' | 'streak';
```

**5B. Update `stokely-frontend/src/api/api.ts`:**
```typescript
habits: {
    list: (view: DashboardView = 'daily', date?: string) => req<HabitType[]>(`/habits?view=${view}${date ? `&date=${date}` : ''}`),
    create: (data) => req<HabitType>('/habits', { method:'POST', body: JSON.stringify(data) }),
    update: (id, changes) => req<HabitType>(`/habits/${id}`, { method:'PUT', body: JSON.stringify(changes) }),
    remove: (id) => req<void>(`/habits/${id}`, { method:'DELETE' }),
    logComplete: (id, date?) => req<void>(`/habits/${id}/log`, { method:'POST', body: JSON.stringify({ date: date ?? '' }) }),
    logUncomplete: (id, date?) => req<void>(`/habits/${id}/log`, { method:'DELETE', body: JSON.stringify({ date: date ?? '' }) }),
    getStreak: (id) => req<StreakDetail>(`/habits/${id}/streak`),
},
push: {
    getVapidKey: () => req<{ publicKey: string }>('/push/vapid-public'),
    subscribe: (sub) => req<void>('/push/subscribe', { method:'POST', body: JSON.stringify(sub) }),
},
user: {
    changePassword: (currentPassword, newPassword) => req<void>('/auth/password', { method:'PUT', body: JSON.stringify({ currentPassword, newPassword }) }),
    exportData: () => req<unknown>('/user/export'),
    deleteAccount: (password) => req<void>('/user/account', { method:'DELETE', body: JSON.stringify({ password }) }),
},
```

